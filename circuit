// --- Gemini API Helper with Exponential Backoff ---
async function fetchWithRetry(url, options, retries = 5) {
  const delays = [1000, 2000, 4000, 8000, 16000];
  for (let i = 0; i < retries; i++) {
    try {
      const response = await fetch(url, options);
      if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
      return await response.json();
    } catch (e) {
      if (i === retries - 1) throw e;
      await new Promise(res => setTimeout(res, delays[i]));
    }
  }
}

// --- Physics Engine: Linear Algebra Solver ---
function solveLinearSystem(A, b) {
  const n = A.length;
  const x = new Array(n).fill(0);
  const mat = A.map(row => [...row]);
  const rhs = [...b];

  for (let i = 0; i < n; i++) {
    let maxEl = Math.abs(mat[i][i]), maxRow = i;
    for (let k = i + 1; k < n; k++) {
      if (Math.abs(mat[k][i]) > maxEl) { maxEl = Math.abs(mat[k][i]); maxRow = k; }
    }

    [mat[i], mat[maxRow]] = [mat[maxRow], mat[i]];
    [rhs[i], rhs[maxRow]] = [rhs[maxRow], rhs[i]];

    if (Math.abs(mat[i][i]) < 1e-12) return null;

    for (let k = i + 1; k < n; k++) {
      const c = -mat[k][i] / mat[i][i];
      for (let j = i; j < n; j++) {
        if (i === j) mat[k][j] = 0;
        else mat[k][j] += c * mat[i][j];
      }
      rhs[k] += c * rhs[i];
    }
  }

  for (let i = n - 1; i >= 0; i--) {
    x[i] = rhs[i] / mat[i][i];
    for (let k = i - 1; k >= 0; k--) {
      rhs[k] -= mat[k][i] * x[i];
    }
  }
  return x;
}

// --- Physics Engine: Circuit Nodal Analysis ---
const solveCircuit = (components) => {
  const nodes = new Set();
  components.forEach(c => { nodes.add(c.n1); nodes.add(c.n2); });
  const nodeList = Array.from(nodes);
  const N = nodeList.length;
  
  if (N === 0) return { voltages: {}, currents: {}, readings: {} };

  const A = Array.from({ length: N }, () => new Array(N).fill(0));
  const b = new Array(N).fill(0);

  for (let i = 0; i < N; i++) A[i][i] += 1e-6;

  components.forEach(c => {
    const i = nodeList.indexOf(c.n1);
    const j = nodeList.indexOf(c.n2);
    
    let R = 1e-6; 
    let E = 0;    

    if (c.type === 'resistor') R = Math.max(c.val || 1e-6, 1e-6);
    if (c.type === 'voltmeter') R = Infinity;
    if (c.type === 'battery') E = c.val || 0;

    const G = 1 / R;

    A[i][i] += G; 
    A[j][j] += G;
    A[i][j] -= G; 
    A[j][i] -= G;

    const I_norton = E * G;
    b[i] += I_norton;
    b[j] -= I_norton;
  });

  const x = solveLinearSystem(A, b);
  if (!x) return { voltages: {}, currents: {}, readings: {}, error: true };

  const voltages = {};
  nodeList.forEach((n, idx) => { voltages[n] = x[idx]; });

  const currents = {};
  const readings = {};

  components.forEach(c => {
    const v1 = voltages[c.n1];
    const v2 = voltages[c.n2];
    
    let R = 1e-6;
    let E = 0;
    if (c.type === 'resistor') R = Math.max(c.val || 1e-6, 1e-6);
    if (c.type === 'voltmeter') R = Infinity;
    if (c.type === 'battery') E = c.val || 0;

    const branchCurrent = R === Infinity ? 0 : (v1 - v2 - E) / R; 
    currents[c.id] = Math.abs(branchCurrent);

    if (c.type === 'voltmeter') readings[c.id] = v1 - v2;
    if (c.type === 'ammeter') readings[c.id] = Math.abs(branchCurrent);
  });

  return { voltages, currents, readings, error: false };
};


// --- Message Formatter for LaTeX & Markdown ---
const FormattedMessage = ({ text }) => {
  const [isKatexLoaded, setIsKatexLoaded] = useState(typeof window !== 'undefined' && !!window.katex);

  useEffect(() => {
    if (isKatexLoaded) return;
    const interval = setInterval(() => {
      if (window.katex) {
        setIsKatexLoaded(true);
        clearInterval(interval);
      }
    }, 100);
    return () => clearInterval(interval);
  }, [isKatexLoaded]);

  if (!isKatexLoaded) {
    return <span className="whitespace-pre-wrap">{text}</span>;
  }

  // Split by Display Math ($$) and Inline Math ($)
  const parts = text.split(/(\$\$[\s\S]*?\$\$|\$[\s\S]*?\$)/g);
  
  return (
    <span className="whitespace-pre-wrap">
      {parts.map((part, index) => {
        if (part.startsWith('$$') && part.endsWith('$$')) {
          const math = part.slice(2, -2);
          try {
            const html = window.katex.renderToString(math, { displayMode: true, throwOnError: false });
            return <span key={index} dangerouslySetInnerHTML={{ __html: html }} className="block my-2 text-center" />;
          } catch (e) {
            return <span key={index}>{part}</span>;
          }
        } else if (part.startsWith('$') && part.endsWith('$')) {
          const math = part.slice(1, -1);
          try {
            const html = window.katex.renderToString(math, { displayMode: false, throwOnError: false });
            return <span key={index} dangerouslySetInnerHTML={{ __html: html }} />;
          } catch (e) {
            return <span key={index}>{part}</span>;
          }
        }
        
        // Handle basic bold markdown for normal text
        const boldParts = part.split(/(\*\*[\s\S]*?\*\*)/g);
        return (
          <React.Fragment key={index}>
            {boldParts.map((bp, i) => {
              if (bp.startsWith('**') && bp.endsWith('**')) {
                return <strong key={i} className="font-bold text-slate-100">{bp.slice(2, -2)}</strong>;
              }
              return <React.Fragment key={i}>{bp}</React.Fragment>;
            })}
          </React.Fragment>
        );
      })}
    </span>
  );
};


// --- 3D Roller Coaster Analogy Component ---
const parseNode = (nodeStr) => {
  const [x, y] = nodeStr.split(',').map(Number);
  return { x, y };
};

const RollerCoasterView = ({ components, simResult }) => {
  const { voltages, currents, error } = simResult;

  // Free 3D Camera State
  const [camAngle, setCamAngle] = useState({ yaw: -Math.PI / 4, pitch: Math.PI / 6 });
  const [isDragging, setIsDragging] = useState(false);
  const [lastPos, setLastPos] = useState({ x: 0, y: 0 });

  const handlePointerDown = (e) => {
    setIsDragging(true);
    setLastPos({ x: e.clientX, y: e.clientY });
    e.currentTarget.setPointerCapture(e.pointerId);
  };

  const handlePointerMove = (e) => {
    if (!isDragging) return;
    const deltaX = e.clientX - lastPos.x;
    const deltaY = e.clientY - lastPos.y;
    setCamAngle(prev => ({
      yaw: prev.yaw - deltaX * 0.01,
      // Clamp pitch between slightly above 0 and 90 degrees
      pitch: Math.max(0.05, Math.min(Math.PI / 2 - 0.05, prev.pitch - deltaY * 0.01))
    }));
    setLastPos({ x: e.clientX, y: e.clientY });
  };

  const handlePointerUp = (e) => {
    setIsDragging(false);
    e.currentTarget.releasePointerCapture(e.pointerId);
  };

  if (components.length === 0) {
    return (
      <div className="bg-[#0f172a] border border-slate-800 rounded-2xl shadow-2xl relative w-full h-[400px] xl:h-[600px] flex items-center justify-center overflow-hidden">
        <p className="text-slate-500 flex flex-col items-center gap-2">
          <TrendingUp className="w-8 h-8 text-slate-600" />
          Draw a circuit to view 3D model
        </p>
      </div>
    );
  }

  if (error) {
    return (
      <div className="bg-[#0f172a] border border-slate-800 rounded-2xl shadow-2xl relative w-full h-[400px] xl:h-[600px] flex items-center justify-center overflow-hidden">
        <p className="text-red-500/80 flex flex-col items-center gap-2">
          <AlertCircle className="w-8 h-8" />
          Circuit error prevents 3D render
        </p>
      </div>
    );
  }

  // Calculate Map Bounds
  const nodes = components.flatMap(c => [parseNode(c.n1), parseNode(c.n2)]);
  const xs = nodes.map(n => n.x);
  const ys = nodes.map(n => n.y);
  const minX = Math.min(...xs), maxX = Math.max(...xs);
  const minY = Math.min(...ys), maxY = Math.max(...ys);
  const cx = (minX + maxX) / 2;
  const cy = (minY + maxY) / 2;

  // Plane Size (pad bounding box)
  const pad = 80;
  const pMinX = minX - cx - pad, pMaxX = maxX - cx + pad;
  const pMinY = minY - cy - pad, pMaxY = maxY - cy + pad;

  // ABSOLUTE Z Scaling (fixes Issue: Height reflecting Voltage accurately)
  const vs = Object.values(voltages);
  const minV = Math.min(...vs, 0);
  const zScale = 20; // Exact pixels per volt. A 100V circuit will be 2000px tall!

  // Full 3D Projection Function based on Dynamic Camera Angles
  const toIso = (x, y, z) => {
    const dx = x - cx;
    const dy = y - cy;
    
    // Rotate around Z axis (Yaw)
    const rx = dx * Math.cos(camAngle.yaw) - dy * Math.sin(camAngle.yaw);
    const ry = dx * Math.sin(camAngle.yaw) + dy * Math.cos(camAngle.yaw);
    
    // Rotate around X axis (Pitch)
    const dz = z * zScale - minV * zScale;
    const px = rx;
    const py = ry * Math.cos(camAngle.pitch) - dz * Math.sin(camAngle.pitch);
    
    return { x: px, y: py };
  };

  const planeCorners = (z) => [
    toIso(cx + pMinX, cy + pMinY, z),
    toIso(cx + pMaxX, cy + pMinY, z),
    toIso(cx + pMaxX, cy + pMaxY, z),
    toIso(cx + pMinX, cy + pMaxY, z)
  ];

  const levels = Array.from(new Set(vs.map(v => Math.round(v * 10) / 10)));

  // Dynamic ViewBox Calculation (Automatically zooms camera out for tall circuits)
  let isoMinX = Infinity, isoMaxX = -Infinity;
  let isoMinY = Infinity, isoMaxY = -Infinity;
  
  const addPt = (p) => {
    if (p.x < isoMinX) isoMinX = p.x;
    if (p.x > isoMaxX) isoMaxX = p.x;
    if (p.y < isoMinY) isoMinY = p.y;
    if (p.y > isoMaxY) isoMaxY = p.y;
  };

  levels.forEach(l => planeCorners(l).forEach(addPt));
  components.forEach(c => {
    addPt(toIso(parseNode(c.n1).x, parseNode(c.n1).y, voltages[c.n1] || 0));
    addPt(toIso(parseNode(c.n2).x, parseNode(c.n2).y, voltages[c.n2] || 0));
    addPt(toIso(parseNode(c.n1).x, parseNode(c.n1).y, minV)); // Add Ground shadows to bounds
    addPt(toIso(parseNode(c.n2).x, parseNode(c.n2).y, minV));
  });

  const vbPad = 60;
  const vbWidth = Math.max(800, isoMaxX - isoMinX + vbPad * 2);
  const vbHeight = Math.max(600, isoMaxY - isoMinY + vbPad * 2);
  const scaleFactor = Math.max(1, Math.max(vbWidth / 800, vbHeight / 600)); // Keeps strokes thick when zoomed out

  // Depth Sorting based on rotated camera coordinates (Back to Front)
  const getDepth = (x, y) => {
    const dx = x - cx;
    const dy = y - cy;
    // Y-axis distance relative to the camera after yaw rotation
    return dx * Math.sin(camAngle.yaw) + dy * Math.cos(camAngle.yaw);
  };

  const depth = (c) => {
     const n1 = parseNode(c.n1), n2 = parseNode(c.n2);
     // Depth is the center of the component
     return getDepth((n1.x + n2.x) / 2, (n1.y + n2.y) / 2);
  };
  
  const sortedComps = [...components].sort((a, b) => depth(a) - depth(b));

  return (
    <div className="bg-[#0f172a] border border-slate-800 rounded-2xl shadow-2xl relative w-full h-[400px] xl:h-[600px] overflow-hidden select-none">
      
      {/* Overlay Legend */}
      <div className="absolute top-4 left-4 bg-slate-900/80 backdrop-blur border border-slate-700/50 px-3 py-2 rounded-lg text-xs font-mono text-slate-300 z-10 pointer-events-none">
        <div className="font-bold text-white mb-2 flex items-center gap-2"><TrendingUp className="w-4 h-4 text-orange-400" /> Roller Coaster Analogy</div>
        <div className="grid grid-cols-2 gap-x-4 gap-y-1 text-[10px] text-slate-400">
          <span>Height</span> <span className="text-right text-orange-400">Voltage Drop</span>
          <span>Flow Speed</span> <span className="text-right text-yellow-400">Current</span>
          <span>Lift Hill</span> <span className="text-right text-green-400">Battery</span>
          <span>Slope</span> <span className="text-right text-red-400">Resistor</span>
          <span>Flat Path</span> <span className="text-right text-slate-400">Wire</span>
        </div>
      </div>

      {/* Free Look Hint */}
      <div className="absolute bottom-4 right-4 bg-slate-900/80 backdrop-blur border border-slate-700/50 px-3 py-2 rounded-lg text-xs font-bold text-slate-400 z-10 pointer-events-none flex items-center gap-2">
        <Move3d className="w-4 h-4" /> Drag to Rotate
      </div>

      <svg 
        viewBox={`${isoMinX - vbPad} ${isoMinY - vbPad} ${vbWidth} ${vbHeight}`} 
        className="w-full h-full block cursor-grab active:cursor-grabbing"
        onPointerDown={handlePointerDown}
        onPointerMove={handlePointerMove}
        onPointerUp={handlePointerUp}
        onPointerLeave={handlePointerUp}
      >
        {/* Render Translucent Voltage Planes */}
        {levels.map((level, i) => (
          <polygon
            key={`plane-${i}`}
            points={planeCorners(level).map(p => `${p.x},${p.y}`).join(' ')}
            fill="rgba(249, 115, 22, 0.05)"
            stroke="rgba(249, 115, 22, 0.2)"
            strokeWidth={1 * scaleFactor}
          />
        ))}

        {/* Render Components */}
        {sortedComps.map((c) => {
          const n1 = parseNode(c.n1);
          const n2 = parseNode(c.n2);
          const v1 = voltages[c.n1] || 0;
          const v2 = voltages[c.n2] || 0;

          // Calculate Center Path
          const pt1 = toIso(n1.x, n1.y, v1);
          const pt2 = toIso(n2.x, n2.y, v2);

          // Calculate Flat Path Geometry in true 3D/Isometric space
          const W = 12; // Half-width of the track in circuit grid units
          const dx2d = n2.x - n1.x;
          const dy2d = n2.y - n1.y;
          const len2d = Math.hypot(dx2d, dy2d) || 1;
          const nx = (-dy2d / len2d) * W;
          const ny = (dx2d / len2d) * W;

          // 4 corners of the elevated track polygon
          const pLeft1 = toIso(n1.x + nx, n1.y + ny, v1);
          const pRight1 = toIso(n1.x - nx, n1.y - ny, v1);
          const pRight2 = toIso(n2.x - nx, n2.y - ny, v2);
          const pLeft2 = toIso(n2.x + nx, n2.y + ny, v2);

          // 4 corners of the ground shadow polygon
          const gLeft1 = toIso(n1.x + nx, n1.y + ny, minV);
          const gRight1 = toIso(n1.x - nx, n1.y - ny, minV);
          const gRight2 = toIso(n2.x - nx, n2.y - ny, minV);
          const gLeft2 = toIso(n2.x + nx, n2.y + ny, minV);

          const isBattery = c.type === 'battery';
          const isResistor = c.type === 'resistor';
          
          let trackColor = '#64748b'; // Slate grey for Wires
          if (isBattery) trackColor = '#22c55e';
          if (isResistor) trackColor = '#ef4444';
          if (c.type === 'ammeter' || c.type === 'voltmeter') trackColor = '#3b82f6';

          let R = 1e-6; let E = 0;
          if (isResistor) R = Math.max(c.val || 1e-6, 1e-6);
          if (c.type === 'voltmeter') R = Infinity;
          if (isBattery) E = c.val || 0;

          const branchCurrent = R === Infinity ? 0 : (v1 - v2 - E) / R;
          let startIso = pt1, endIso = pt2;
          if (branchCurrent < -0.001) {
            startIso = pt2; endIso = pt1;
          } 

          const currentAbs = Math.abs(branchCurrent);
          const hasFlow = currentAbs > 0.001;
          const dist = Math.hypot(endIso.x - startIso.x, endIso.y - startIso.y);

          const speed = Math.max(8, currentAbs * 120); 
          const dashSpacing = 24 * scaleFactor;
          const cycleDuration = dashSpacing / (speed * scaleFactor);

          return (
            <g key={c.id}>
              {/* Ground Shadow Polygon */}
              <polygon 
                points={`${gLeft1.x},${gLeft1.y} ${gRight1.x},${gRight1.y} ${gRight2.x},${gRight2.y} ${gLeft2.x},${gLeft2.y}`} 
                fill="#0f172a" opacity="0.6" 
              />
              
              {/* Voltage Height Visualizers (Center lines) */}
              <line x1={toIso(n1.x, n1.y, minV).x} y1={toIso(n1.x, n1.y, minV).y} x2={pt1.x} y2={pt1.y} stroke="#475569" strokeWidth={1 * scaleFactor} strokeDasharray={`${4*scaleFactor} ${4*scaleFactor}`} />
              <line x1={toIso(n2.x, n2.y, minV).x} y1={toIso(n2.x, n2.y, minV).y} x2={pt2.x} y2={pt2.y} stroke="#475569" strokeWidth={1 * scaleFactor} strokeDasharray={`${4*scaleFactor} ${4*scaleFactor}`} />

              {/* Elevated Flat Track Polygon */}
              <polygon 
                points={`${pLeft1.x},${pLeft1.y} ${pRight1.x},${pRight1.y} ${pRight2.x},${pRight2.y} ${pLeft2.x},${pLeft2.y}`} 
                fill={trackColor} 
                stroke="#1e293b" 
                strokeWidth={1 * scaleFactor} 
                strokeLinejoin="round" 
              />
              
              {/* Track Edges/Rails for architectural detail */}
              <line x1={pLeft1.x} y1={pLeft1.y} x2={pLeft2.x} y2={pLeft2.y} stroke="#0f172a" strokeWidth={1.5 * scaleFactor} />
              <line x1={pRight1.x} y1={pRight1.y} x2={pRight2.x} y2={pRight2.y} stroke="#0f172a" strokeWidth={1.5 * scaleFactor} />

              {/* Continuous Stream of Flowing Charge Beads (down the center pt1 -> pt2) */}
              {hasFlow && dist > 1 && (
                <line
                  x1={startIso.x} y1={startIso.y} x2={endIso.x} y2={endIso.y}
                  stroke="#facc15"
                  strokeWidth={8 * scaleFactor}
                  strokeDasharray={`0 ${dashSpacing}`}
                  strokeLinecap="round"
                >
                  <animate 
                    attributeName="stroke-dashoffset" 
                    from={dashSpacing} 
                    to="0" 
                    dur={`${cycleDuration}s`} 
                    repeatCount="indefinite" 
                  />
                </line>
              )}

              {/* Label - Anchored relative to the screen to always point UP regardless of rotation */}
              {c.val > 0 && (
                <text 
                  x={(pt1.x + pt2.x) / 2} 
                  y={(pt1.y + pt2.y) / 2 - (40 * scaleFactor)} 
                  fill={isBattery ? "#4ade80" : "#f87171"} 
                  fontSize={13 * scaleFactor} fontWeight="bold" textAnchor="middle" className="drop-shadow-md"
                >
                  {c.val}{isBattery ? 'V' : 'Ω'}
                </text>
              )}
            </g>
          );
        })}
      </svg>
    </div>
  );
};


export default function App() {
