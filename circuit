  const [isGenerating, setIsGenerating] = useState(false);
  const [genAnalysis, setGenAnalysis] = useState('');

  // Chat State
  const [chatMessages, setChatMessages] = useState([
    { role: 'model', text: "Hi! I'm your AI Physics Tutor. Ask me any questions about the circuit you're building, or hit 'Analyze Circuit' for a quick breakdown!" }
  ]);
  const [chatInput, setChatInput] = useState('');
  const [isChatting, setIsChatting] = useState(false);
  const chatScrollRef = useRef(null);
  
  // History State
  const [history, setHistory] = useState([]);
  const svgRef = useRef(null);

  const tools = [
    { id: 'select', icon: <MousePointer2 className="w-5 h-5" />, label: 'Select' },
    { id: 'wire', icon: <Slash className="w-5 h-5" />, label: 'Wire' },
    { id: 'battery', icon: <Zap className="w-5 h-5" />, label: 'Battery', defaultVal: 9 },
    { id: 'resistor', icon: <Activity className="w-5 h-5" />, label: 'Resistor', defaultVal: 10 },
    { id: 'ammeter', icon: <Circle className="w-5 h-5" />, label: 'Ammeter' },
    { id: 'voltmeter', icon: <Circle className="w-5 h-5" />, label: 'Voltmeter' },
    { id: 'delete', icon: <Trash2 className="w-5 h-5" />, label: 'Delete' },
  ];

  const simResult = useMemo(() => solveCircuit(components), [components]);

  const pushHistory = () => {
    setHistory(prev => [...prev, components]);
  };

  const handleUndo = () => {
    if (history.length === 0) return;
    const previousState = history[history.length - 1];
    setComponents(previousState);
    setHistory(prev => prev.slice(0, -1));
    setSelectedCompId(null);
    setStartNode(null);
  };

